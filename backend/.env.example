# Copy this file to .env and fill in real values. Never commit .env itself.

# ── DATABASE ──────────────────────────────────────────────────────────────────
# PRODUCTION (Render + Neon): paste your Neon connection string below
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/flatshare?sslmode=require"

# LOCAL DEV (SQLite, zero-config): comment out the line above and use this:
# DATABASE_URL="file:./dev.db"
# Then also change provider = "postgresql" → "sqlite" in prisma/schema.prisma
# and run: npx prisma migrate dev --name init

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=4000

# ── AI SUMMARY (optional) ─────────────────────────────────────────────────────
# Enables the plain-English Import Report summary powered by Claude.
# Imports work fully without this; the AI paragraph just won't appear.
ANTHROPIC_API_KEY=
