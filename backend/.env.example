# Copy this file to .env and fill in real values. Never commit .env itself.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/flatshare_ledger"

# Port the Express server listens on
PORT=4000

# Optional: enables the AI import-summary feature (DECISIONS.md #9).
# If unset, imports still work fully; the Import Report just won't include
# the natural-language summary.
ANTHROPIC_API_KEY=
